# LLM Provider: "gemini", "groq", or "auto" (auto picks whichever key is set, prefers groq)
LLM_PROVIDER=auto

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Groq Cloud API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to Firebase service account JSON (optional, for Firebase Admin SDK)
# If not set, Firebase Admin will try to use Application Default Credentials
FIREBASE_CREDENTIALS_PATH=

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
